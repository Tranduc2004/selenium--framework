<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    testng.xml - Bài 1: Kiểm tra BasePage và BaseTest
    parallel="methods" thread-count="3" → 3 Chrome mở cùng lúc, mỗi thread có WebDriver riêng
    Xác minh ThreadLocal hoạt động đúng, không có race condition
-->
<suite name="Bt1-BasePageBaseTest" parallel="methods" thread-count="3" verbose="2">

    <parameter name="browser" value="chrome"/>
    <parameter name="env" value="dev"/>

    <test name="Bt1 - BasePage and BaseTest Verification">
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

</suite>
