{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "job", "id", "createdAt", "_meta"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "job": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "_meta": {
      "type": "object",
      "required": ["powered_by", "docs_url", "upgrade_url", "example_url", "variant", "message", "cta", "context"],
      "properties": {
        "powered_by": { "type": "string", "minLength": 1 },
        "docs_url": { "type": "string", "format": "uri" },
        "upgrade_url": { "type": "string", "format": "uri" },
        "example_url": { "type": "string", "format": "uri" },
        "variant": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "cta": {
          "type": "object",
          "required": ["label", "url"],
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "url": { "type": "string", "format": "uri" }
          },
          "additionalProperties": false
        },
        "context": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
